// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Player {
  id   Int    @id @default(autoincrement())
  name String

  // Soft delete
  leavedAt DateTime? @db.Date
  isActive Boolean   @default(true)

  // Relations
  stats            PlayerBossStat[]
  castleEntries    CastleEntry[]
  guildBossEntries GuildBossEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

// Castle Rush
model CastleBoss {
  id      Int    @id @default(autoincrement())
  name    String
  weekday Int // 0 = Sunday, 6 = Saturday

  leaderboards CastleLeaderboard[]
  stats        PlayerBossStat[]

  createdAt DateTime @default(now())

  @@unique([weekday]) // ป้องกันซ้ำวัน
  @@map("Boss")
}

model CastleLeaderboard {
  id   Int      @id @default(autoincrement())
  date DateTime @db.Date

  boss   CastleBoss @relation(fields: [bossId], references: [id], onDelete: Cascade)
  bossId Int

  entries CastleEntry[]

  createdAt DateTime @default(now())

  // 1 boss ต่อ 1 วัน
  @@unique([date, bossId])
  @@index([date])
  @@map("DailyLeaderboard")
}

enum STATE {
  HIGHER
  LOWER
  SWEEP_FREE
  SWEEP_PAY
}

model CastleEntry {
  id Int @id @default(autoincrement())

  leaderboard   CastleLeaderboard @relation(fields: [leaderboardId], references: [id], onDelete: Cascade)
  leaderboardId Int

  player   Player @relation(fields: [playerId], references: [id])
  playerId Int

  score Int   @default(0)
  state STATE

  createdAt DateTime @default(now())

  // 1 คนมีได้ 1 score ต่อวันต่อ boss
  @@unique([leaderboardId, playerId])
  // ใช้ sort leaderboard เร็ว ๆ
  @@index([leaderboardId, score])
  @@map("DailyLeaderboardEntry")
}

model PlayerBossStat {
  id Int @id @default(autoincrement())

  player   Player @relation(fields: [playerId], references: [id])
  playerId Int

  boss   CastleBoss @relation(fields: [bossId], references: [id])
  bossId Int

  maxScore  Int @default(0)
  lastScore Int @default(0)

  updatedAt DateTime @updatedAt

  // 1 stat ต่อ player ต่อ boss
  @@unique([playerId, bossId])
  @@index([bossId, maxScore])
}

// Boss Guild
model GuildBoss {
  id   Int    @id @default(autoincrement())
  name String

  entries GuildBossEntry[]
}

model GuildBossSeason {
  id        Int      @id @default(autoincrement())
  startDate DateTime @db.Date
  endDate   DateTime @db.Date

  entries GuildBossEntry[]
}

model GuildBossEntry {
  id Int @id @default(autoincrement())

  season   GuildBossSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId Int

  boss   GuildBoss @relation(fields: [bossId], references: [id])
  bossId Int

  player   Player @relation(fields: [playerId], references: [id])
  playerId Int

  score Int
  hits  Int

  @@unique([seasonId, bossId, playerId])
}